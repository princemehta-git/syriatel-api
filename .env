# Port for the API server (default 3000)
PORT=3009

# Use in-memory store (boolean). true = store in RAM (no MySQL; data lost on restart). false = use MySQL (default).
USE_MEMORY=false

# MySQL (used when USE_MEMORY is false). DB and tables are created on startup if missing.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=syriatel_api

# Dynamic devices: when false (default), use fixed device from syriatel_api_calls.js and captured hashes (no hash generation).
# When true: use deterministic device per apiKey and generate hash via hash.js.
USE_DYNAMIC_DEVICES=false

# Force create hash: when true, always compute new hashes (even if USE_DYNAMIC_DEVICES is false).
# When false: use default/captured hashes from constants.js (whether USE_DYNAMIC_DEVICES is true or false).
FORCE_CREATE_HASH=false

# Hash algorithm mode: sha256 (default), hmac, or cash. Use if server accepts a different variant.
# SYRIATEL_HASH_MODE=sha256

# Optional: URL of a hash proxy that returns { hash } for POST { style, privateKey, params, device }.
# SYRIATEL_HASH_PROXY_URL=http://localhost:9999/hash

# Direct request timeout (ms); after this, fallback to proxy if PROXY_ENABLED.
DIRECT_TIMEOUT_MS=5000
# Enable proxy fallback when direct request times out or fails (network/abort).
PROXY_ENABLED=true
# SOCKS5 proxy URL used for fallback (e.g. socks5://127.0.0.1:1081).
PROXY_URL=socks5://127.0.0.1:1081

# Max retries for checkCustomer and transfer (each tries until success or this many attempts). Default 5.
PAYMENT_RETRY_ATTEMPTS=5

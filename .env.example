# Port for the API server (default 3000)
PORT=3009

# Use in-memory store (boolean). true = store in RAM (no MySQL; data lost on restart). false = use MySQL (default).
USE_MEMORY=false

# MySQL (used when USE_MEMORY is false). DB and tables are created on startup if missing.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
# Use syriatel_api_new if syriatel_api has corrupted/orphan files (run npm run db:fix for details)
MYSQL_DATABASE=syriatel_api_new

# Dynamic devices: when false (default), use fixed device from syriatel_api_calls.js and captured hashes (no hash generation).
# When true: use deterministic device per apiKey and generate hash via hash.js.
USE_DYNAMIC_DEVICES=false

# Force create hash: when true, always compute new hashes (even if USE_DYNAMIC_DEVICES is false).
# When false: use default/captured hashes from constants.js (whether USE_DYNAMIC_DEVICES is true or false).
FORCE_CREATE_HASH=false

# Hash algorithm mode: sha256 (default), hmac, or cash. Use if server accepts a different variant.
# SYRIATEL_HASH_MODE=sha256

# Optional: URL of a hash proxy that returns { hash } for POST { style, privateKey, params, device }.
# SYRIATEL_HASH_PROXY_URL=http://localhost:9999/hash

# --- Timeout & Retry ---
# Timeout (ms) for ALL requests (both direct and proxy). If no response within this window, abort and retry.
REQUEST_TIMEOUT_MS=5000

# Enable proxy fallback when direct request times out or fails (network/abort).
PROXY_ENABLED=true
# Force proxy only: when true, skip direct and always use proxy.
FORCE_PROXY_ENABLED=false
# SOCKS5 proxy URL used for fallback (e.g. socks5://127.0.0.1:1081).
PROXY_URL=socks5h://127.0.0.1:1081

# Retry attempts per scenario (only retries on timeout/network error; any JSON response = no retry):
#   Scenario 1 – FORCE_PROXY_ENABLED=true: proxy-only retries. Default 3.
FORCE_PROXY_RETRY_ATTEMPTS=5
#   Scenario 2 – PROXY_ENABLED=true, FORCE_PROXY=false:
#     Direct phase retries (before falling back to proxy). Default 2.
DIRECT_RETRY_ATTEMPTS=3
#     Proxy fallback phase retries (after all direct attempts fail). Default 2.
PROXY_RETRY_ATTEMPTS=3
#     Number of full direct→proxy cycles. After one cycle (3 direct + 3 proxy) fails,
#     starts the next cycle from direct again. Default 1 (no looping).
PROXY_FALLBACK_CYCLES=5
#   Scenario 3 – Proxy off, direct only: retries. Default 30.
DIRECT_ONLY_RETRY_ATTEMPTS=30

# Max retries for checkCustomer and transfer (outer retry loop, 1 network attempt each).
# Retries only on no response/timeout. Any JSON response (code 1 or other) → no retry. Default 5.
PAYMENT_RETRY_ATTEMPTS=5

# Deduplication window (ms) for transfers. Identical transfers (same user + recipient + amount) within
# this window after a successful/uncertain transfer are blocked. Default 30000 (30s).
TRANSFER_DEDUP_WINDOW_MS=30000

# --- Admin Panel ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_JWT_SECRET=syriatel-admin-secret-change-me-in-production
